# Blog server bind address.
# Optional. Defaults to 0.0.0.0:8080 when omitted.
BLOG_BIND_ADDR=0.0.0.0:8080

# Optional log filter for tracing-subscriber.
# Falls back to RUST_LOG, then to a sane info-level default.
BLOG_LOG=info,myblog004=debug,tower_http=info

# PostgreSQL connection string for the application database.
# Required.
# If your Postgres proxy rejects TLS negotiation, set `sslmode=disable`.
BLOG_DATABASE_URL=postgres://user:password@hostname:5432/database

# Public site base URL used for canonical links and feeds.
# Required. Must be an absolute URL.
BLOG_BASE_URL=https://example.com

# Human-readable site title shown in rendered pages and logs.
# Required.
BLOG_TITLE=My Blog

# Initial administrator username loaded at startup.
# Required.
ADMIN_USERNAME=admin

# Initial administrator password loaded at startup.
# Required.
ADMIN_PASSWORD=change-me
