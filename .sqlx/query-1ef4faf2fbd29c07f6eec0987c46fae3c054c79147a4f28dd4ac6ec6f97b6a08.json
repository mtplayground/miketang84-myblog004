{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                p.id,\n                p.slug,\n                p.title,\n                p.body_md,\n                p.body_html,\n                p.excerpt,\n                p.status,\n                p.published_at,\n                p.created_at,\n                p.updated_at\n            FROM posts p\n            INNER JOIN post_tags pt ON pt.post_id = p.id\n            INNER JOIN tags t ON t.id = pt.tag_id\n            WHERE t.slug = $1 AND p.status = 'published'\n            ORDER BY p.published_at DESC NULLS LAST, p.created_at DESC\n            ",
